# Copy → Railway → Booking-Tour → Variables → Raw Editor
# Replace YOUR_DOMAIN and paste secrets from application-local.properties

SPRING_PROFILES_ACTIVE=prod

SPRING_DATASOURCE_URL=jdbc:mysql://${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}
SPRING_DATASOURCE_USERNAME=${{MySQL.MYSQLUSER}}
SPRING_DATASOURCE_PASSWORD=${{MySQL.MYSQLPASSWORD}}

APP_BASE_URL=https://YOUR_DOMAIN.up.railway.app

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
VNP_TMN_CODE=
VNP_HASH_SECRET=
NEWS_API_TOKEN=
GROQ_API_KEY=

# Optional (prod profile derives return/ipn from APP_BASE_URL if omitted)
# VNP_RETURN_URL=https://YOUR_DOMAIN.up.railway.app/payment/vnpay-callback
# VNP_IPN_URL=https://YOUR_DOMAIN.up.railway.app/payment/vnpay-ipn
