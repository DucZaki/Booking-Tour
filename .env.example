# Copy file này thành .env và điền giá trị thật (file .env không commit lên Git).
# Spring Boot tự nạp .env khi khởi động (xem EnvBootstrap.java).

SPRING_PROFILES_ACTIVE=local

# MySQL local
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/booking_tour?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password
SPRING_FLYWAY_REPAIR_ON_MIGRATE=true

APP_BASE_URL=http://localhost:8080

# OAuth2 (để disabled nếu chưa có)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# VNPay Sandbox
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNP_RETURN_URL=http://localhost:8080/payment/vnpay-callback
VNP_IPN_URL=http://localhost:8080/payment/vnpay-ipn

# Amadeus / News
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
NEWS_API_TOKEN=

# Chatbot AI (ưu tiên: Groq → OpenRouter → Gemini)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
GEMINI_API_KEY=

# Gmail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_ENABLED=true

# Tuỳ chọn
BOOKING_CUTOFF_HOURS=24
DEPARTURE_REMINDER_ENABLED=true
DEPARTURE_REMINDER_DAYS_BEFORE=1
TOUR_BOOTSTRAP_ON_STARTUP=false
